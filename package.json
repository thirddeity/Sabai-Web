{
  "name": "sabai-web",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun --bun run --filter '@sabai/*' dev",
    "dev:web": "bun --bun run --cwd apps/web dev",
    "dev:api": "bun --bun run --cwd apps/api dev",
    "typecheck": "bun --bun run --filter '@sabai/*' typecheck",
    "lint": "eslint apps --max-warnings=0",
    "build": "bun --bun run --filter '@sabai/*' build",
    "build:web": "bun --bun run --cwd apps/web build",
    "preview:web": "bun --bun run --cwd apps/web preview"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bun": "^1.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "@ant-design/icons": "6.x"
  }
}
